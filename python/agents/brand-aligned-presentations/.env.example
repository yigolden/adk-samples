# --- GOOGLE CLOUD CONFIGURATION ---
# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=""
# The region for Vertex AI (e.g., us-central1)
GOOGLE_CLOUD_LOCATION="us-central1"
# GCS Bucket for staging deployment assets (e.g., gs://your-bucket-name)
GCP_STAGING_BUCKET=""
# (Optional) Agent Engine ID required if updating an existing deployment, otherwise a new agent will be created on deployment
AGENT_ENGINE_ID=""

# --- MODEL SETTINGS ---
# The Gemini model to use for synthesis and reasoning
GEMINI_MODEL_NAME="gemini-2.5-flash"
# The model to use for generating slide visuals
IMAGE_GENERATION_MODEL="imagen-3.0-generate-002"
# Set to True to use Vertex AI for GenAI calls
GOOGLE_GENAI_USE_VERTEXAI=True

# --- PRESENTATION SETTINGS ---
# GCS URI to your default .pptx template (e.g., gs://your-bucket/Template.pptx), you can download the sample pptx template from the doc/ in the repo and upload to your bucket.
DEFAULT_TEMPLATE_URI=""
# Gemini Enterprise App ID.
AS_APP=""

# --- OPTIONAL: RAG (Retrieval Augmented Generation) ---
# (Optional) Your Vertex AI Search DataStore ID
DATASTORE_ID=""
# Set to 'true' only if DATASTORE_ID is provided
ENABLE_RAG=false

# --- OPTIONAL: DEEP RESEARCH ---
# Set to 'true' only if your project is allowlisted for Deep Research
GOOGLE_CLOUD_PROJECT_NUMBER=""
ENABLE_DEEP_RESEARCH=false

# --- OPTIONAL: SECURITY ---
# (Optional) Vertex AI Model Armor Template ID for prompt/response filtering
MODEL_ARMOR_TEMPLATE_ID=""

# --- DEVELOPMENT ---
# Set to 'true' for local testing to bypass certain cloud checks
LOCAL_DEV=false
